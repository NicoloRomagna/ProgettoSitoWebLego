@startuml
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false

actor Utente
actor Amministratore

rectangle "Sistema Sito Web LEGO" {

  package "Autenticazione" {
    (Registrazione) as UC1
    (Login) as UC2
    (Logout) as UC3
  }

  package "Catalogo Set LEGO" {
    (Visualizza Catalogo Set LEGO) as UC4
    (Aggiungi Set LEGO) as UC5
    (Elimina Set LEGO) as UC6
    (Modifica Set LEGO) as UC7
  }

  package "Catalogo Pezzi e Acquisto" {
    (Visualizza Catalogo Pezzi) as UC8
    (Ricerca Pezzo) as UC9
    (Filtra per Colore) as UC10
    (Seleziona Componenti) as UC11
    (Acquista Pezzi) as UC12
  }

  package "Contenuti e Tutorial" {
    (Visualizza Storia LEGO) as UC13
    (Guarda Video Tutorial) as UC14
    (Visualizza Immagini Costruzione) as UC15
  }
}

